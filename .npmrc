# Supply-chain hardening for the npm CLI path (publish workflows + any
# consumer that uses npm instead of bun). See SECURITY.md.

# Kills the preinstall/postinstall vector used by ua-parser-js, Nx,
# Axios, Bitwarden CLI, and Shai-Hulud v1/v2.
ignore-scripts=true

# 3-day cooldown (days — npm's unit, not seconds). Vulnerability alerts
# bypass this so emergency CVEs are not held up.
min-release-age=3

# Verify sigstore provenance on every installed package.
audit-signatures=true

# Exact-version installs.
save-exact=true

# Quality-of-life: don't print funding messages; treat moderate as a fail.
fund=false
audit-level=high
engine-strict=true

registry=https://registry.npmjs.org/
