{
  "name": "@alien-id/miniapps-react",
  "version": "2.1.0-beta",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alien-id/miniapp-sdk.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@alien-id/miniapps-bridge": "workspace:*",
    "@alien-id/miniapps-contract": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.9.0",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "20.9.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsdown": "0.22.0"
  }
}
