{
  "name": "@alien-id/miniapps-contract",
  "version": "2.1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "artifacts/events.schema.json",
    "artifacts/methods.schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alien-id/miniapp-sdk.git",
    "directory": "packages/contract"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && bun run generate-schemas",
    "test": "bun test tests",
    "generate-schemas": "bun run scripts/generate-schemas.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "tsdown": "0.22.0",
    "typescript-json-schema": "0.67.4"
  }
}
