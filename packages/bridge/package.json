{
  "name": "@alien-id/miniapps-bridge",
  "version": "2.0.0-beta",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./mock": {
      "import": {
        "types": "./dist/mock.d.mts",
        "default": "./dist/mock.mjs"
      },
      "require": {
        "types": "./dist/mock.d.cts",
        "default": "./dist/mock.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alien-id/miniapp-sdk.git",
    "directory": "packages/bridge"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test tests",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@alien-id/miniapps-contract": "workspace:*",
    "emittery": "^1.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "tsdown": "^0.21.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
